          "vantacode-mbt:ai-supply-chain-threats=\"malicious-ml-dependency\""
        ],
        "detection-method": "registry_verification"
      },
      "uuid": "ea330c69-40ed-5834-bb73-af7dfcd8e94d",
      "value": "Dependencies That Don't Exist - LLM-002"
    },
    {
      "description": "Same codebase mixing incompatible approaches from different LLM sessions. Detection method: pattern_analysis. Fix: Pick one pattern per concern and migrate everything to it. Architectural consistency prevents entire classes of bugs.",
      "meta": {
        "kill_chain": [
          "vantacode-dkc:llm-fingerprints"
        ],
        "refs": [
